{
  "name": "steam-server-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx --conditions=react-server server.ts",
    "prebuild": "npm run agent:bundle",
    "agent:bundle": "node scripts/bundle-agent.mjs",
    "build": "next build",
    "start": "tsx --conditions=react-server server.ts",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx --conditions=react-server src/db/seed.ts",
    "agent": "tsx --conditions=react-server agent/cli.ts",
    "agent:run": "powershell -ExecutionPolicy Bypass -NoProfile -File ./scripts/agent-run.ps1",
    "catalog:ingest:local": "node scripts/catalog-ingest-local.mjs",
    "setup:local": "powershell -ExecutionPolicy Bypass -NoProfile -File ./scripts/setup-local.ps1",
    "verify:smoke": "powershell -ExecutionPolicy Bypass -NoProfile -File ./scripts/smoke-verify.ps1",
    "test:ui-section14": "node scripts/ui-section14.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1030.0",
    "@aws-sdk/s3-request-presigner": "^3.1030.0",
    "@base-ui/react": "^1.3.0",
    "@marsidev/react-turnstile": "^1.5.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "commander": "^14.0.0",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.8.0",
    "marked": "^15.0.12",
    "next": "16.2.3",
    "nodemailer": "^8.0.5",
    "postgres": "^3.4.9",
    "rcon-client": "^4.2.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-qr-code": "^2.0.18",
    "server-only": "^0.0.1",
    "shadcn": "^4.2.0",
    "sonner": "^2.0.7",
    "ssh2-sftp-client": "^12.1.1",
    "stripe": "^22.0.1",
    "tailwind-merge": "^3.5.0",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "node-pty": "1.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ssh2-sftp-client": "^9.0.6",
    "@types/ws": "^8.5.14",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.25.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
