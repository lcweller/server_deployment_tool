# Copy to .env.local

DATABASE_URL=postgresql://steamline:steamline@localhost:5432/steamline

# Public URL for emails and verification links (no trailing slash). Required in production/Docker.
# Hosted production (Layer One): https://game.layeroneconstultants.com
APP_PUBLIC_URL=http://localhost:3000

# Optional: public URL for "Add host" enroll command when the dashboard is opened
# on a different origin than agents reach (e.g. localhost vs tunnel). Defaults to window.location.origin.
# NEXT_PUBLIC_APP_URL=https://game.layeroneconstultants.com

# --- Cloudflare Turnstile (recommended when the site is on the public internet) ---
# Docker / production image: set these at runtime (no rebuild). Site key is not secret.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# Local dev with `next dev` only (baked at build for `next build`):
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# Private LAN / self-hosted only: skip captcha (do not use on a public URL)
# STEAMLINE_SKIP_TURNSTILE=1

# --- Email (Mailpit: docker compose up mailpit → localhost:1025) ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=Steamline <noreply@localhost>
# SMTP_USER=
# SMTP_PASS=

# --- Stripe (optional; enables /billing checkout + webhooks) ---
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# --- Cron / jobs (protect ingest + log prune) ---
CRON_SECRET=generate-a-long-random-string
# Optional: retention for agent self-update audit rows (default 30 days)
# AGENT_UPDATE_EVENT_RETENTION_DAYS=30

# --- Queued Steam credentials (dashboard → agent heartbeat) ---
# AES key material for pending Steam passwords at rest (before the agent picks them up).
# Prefer a dedicated long random string in production. Falls back to AUTH_SECRET if unset.
# STEAMLINE_HOST_STEAM_SECRET=

# --- Optional: platform admin emails (comma-separated) for future admin UI ---
PLATFORM_ADMIN_EMAILS=

# --- Agent (host machine, not Next.js): create steamline-agent.env in project root with:
# STEAMLINE_API_KEY=paste-key-from-enroll-output
# Or in PowerShell: $env:STEAMLINE_API_KEY = "your-key"
#
# Optional agent env (see README):
# STEAMLINE_PROVISION_STUB=1          # skip real SteamCMD (dev only)
# STEAMLINE_DATA_ROOT=...             # default ./steamline-data
# STEAMLINE_UNINSTALL_SCRIPT=...      # run before wiping data on host removal (e.g. systemd drop-in)
# STEAMLINE_STEAMCMD_PATH=...         # use existing steamcmd instead of bundled download
# STEAMLINE_AFTER_INSTALL_CMD=...     # optional: start dedicated server; writes steamline.pid for clean shutdown
