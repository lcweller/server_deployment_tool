[Unit]
Description=GameServerOS live installer (runs from ISO/USB live session)
After=network-online.target
Wants=network-online.target
ConditionKernelCommandLine=boot=live

[Service]
Type=oneshot
RemainAfterExit=yes
StandardInput=tty
StandardOutput=tty
StandardError=tty
TTYPath=/dev/console
ExecStartPre=/bin/mkdir -p /var/log
ExecStart=/opt/gameserveros/installer/install-main.sh
TimeoutStartSec=0

[Install]
WantedBy=multi-user.target
