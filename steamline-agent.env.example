# Copy to steamline-agent.env (or use the dashboard curl installer — it creates this file in ~/.steamline/).
# Or paste the apiKey from enroll JSON after:
#   npm run agent -- enroll https://game.layeroneconstultants.com <ENROLLMENT_TOKEN>
#
STEAMLINE_API_KEY=

# Set to 1 to disable automatic restart when the dedicated game process exits (watchdog).
# STEAMLINE_WATCHDOG_DISABLE=1

# During game install (SteamCMD), push log lines to the dashboard this often (ms). Default 1500.
# Lower = more “live” logs and more API traffic. Minimum effective ~250.
# STEAMLINE_INSTALL_LOG_FLUSH_MS=1500

# --- Auto-heal (log-driven fixes during provision / before dedicated launch) ---
# Set to 1 to disable (no chmod on scripts, no apt retry for missing SteamCMD libs).
# STEAMLINE_SELF_HEAL_DISABLE=1
# After a successful host fix, retry SteamCMD once (default on). Set to 0 to disable.
# STEAMLINE_AUTO_RETRY_STEAMCMD=0

# Linux: auto-install firewalld via apt when root and firewall-cmd is missing (bare metal / VM).
# STEAMLINE_SKIP_AUTO_FIREWALL_STACK=1
# In Docker, auto-install is skipped unless you set:
# STEAMLINE_ALLOW_FIREWALL_IN_CONTAINER=1

# --- Licensed SteamCMD (optional; Counter-Strike 2 and similar) ---
# Prefer the dashboard host page "Push to host" — the agent merges these lines for you.
# STEAMLINE_STEAM_USERNAME=
# STEAMLINE_STEAM_PASSWORD=
# STEAMLINE_STEAM_GUARD_CODE=
# Or: STEAMLINE_STEAM_PASSWORD_FILE=/root/.steamline/steam.pass   (chmod 600, single line)
# Interactive only if you want a raw SteamCMD shell: node steamline-agent.cjs steam-login [API_BASE_URL]
